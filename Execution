--Question: "Who are our top 10 customers by total spend over the
---last 12 months, and what region are they from? We want to
---send them a VIP thank-you gift."
 
  SELECT TOP 10
    c.first_name,
    c.last_name,  -- Added last name so you know exactly who to mail the gift to!
    c.region,
    SUM(o.total_amount) AS total_spend
FROM dbo.customers c
INNER JOIN dbo.orders o ON c.customer_id = o.customer_id -- Fixed the ID link
GROUP BY c.first_name, c.last_name, c.region           -- Grouping by the person
ORDER BY total_spend DESC;                             -- Sorting by the biggest spenders

---Question: "Which marketing campaign had the best Return
---on Investment (ROI)? Calculate the total revenue
---generated by each campaign versus its budget."
SELECT
    cm.campaign_name,
    SUM(DISTINCT cm.budget) AS total_strategy_budget, -- Sums unique budgets per name
    SUM(o.total_amount) AS total_revenue,
    -- ROI calculation for the whole strategy
    CAST((SUM(o.total_amount) - SUM(DISTINCT cm.budget)) / SUM(DISTINCT cm.budget) * 100 AS DECIMAL(10,2)) AS total_roi_pct
FROM dbo.marketing_campaigns cm  
INNER JOIN dbo.orders o ON cm.campaign_id = o.campaign_id
GROUP BY cm.campaign_name
ORDER BY total_roi_pct DESC;

---Question: "Find all customers who signed up in 2025 but
---have never placed an order. We need to target them with
--- a 'First Purchase' discount."
SELECT
    c.customer_id,
    c.first_name,
    c.last_name,
    c.email,
    c.signup_date
FROM dbo.customers c
-- 1. LEFT JOIN keeps all customers, even those without orders
LEFT JOIN dbo.orders o ON c.customer_id = o.customer_id
-- 2. Filter for only the 2024 signups
WHERE c.signup_date BETWEEN '2025-01-01' AND '2025-12-31'
-- 3. The "Magic" line: filter for customers who don't exist in the orders table
AND o.order_id IS NULL;

---Question: "Which product category has the highest profit margin?
--- (Profit = Price - Cost of Goods)."
SELECT
    category,
    -- 1. Calculate the average price and cost
    CAST(AVG(price) AS DECIMAL(10,2)) AS avg_price,
    CAST(AVG(cost_of_goods) AS DECIMAL(10,2)) AS avg_cost,
    -- 2. The Margin For227381mula: ((Price - Cost) / Price) * 100
    CAST(AVG((price - cost_of_goods) / price) * 100 AS DECIMAL(10,2)) AS margin_percentage
FROM dbo.products
GROUP BY category
ORDER BY margin_percentage DESC;
